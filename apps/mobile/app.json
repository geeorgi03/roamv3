{
  "expo": {
    "name": "Roam Choreography",
    "slug": "roam-choreography",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "scheme": "roam",
    "ios": {
      "bundleIdentifier": "com.roam.mobile"
    },
    "android": {
      "package": "com.roam.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      }
    },
    "plugins": [
      [
        "expo-router",
        { "root": "app" }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-camera",
      "expo-image-picker"
    ]
  }
}
