{
  "expo": {
    "name": "Roam Choreography",
    "slug": "roam-choreography",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "scheme": "roam",
    "ios": {
      "bundleIdentifier": "com.roam.mobile"
    },
    "android": {
      "package": "com.roam.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      "expo-secure-store",
      "expo-camera",
      "expo-image-picker"
    ],
    "extra": {
      "router": {
        "origin": false,
        "root": "app"
      },
      "eas": {
        "projectId": "96524f01-8def-413a-822f-37d1bcd21cbc"
      }
    }
  }
}
